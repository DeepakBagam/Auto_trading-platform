//@version=5
strategy("Quant Architect Multi Strategy Confluence", overlay=true, pyramiding=0, calc_on_every_tick=false, process_orders_on_close=true, initial_capital=100000)

groupTrend = "Trend Filters"
emaFastLen = input.int(9, "EMA 9", minval=2, group=groupTrend)
emaMidLen = input.int(21, "EMA 21", minval=2, group=groupTrend)
emaSlowLen = input.int(50, "EMA 50", minval=2, group=groupTrend)
rsiLen = input.int(14, "RSI Length", minval=2, group=groupTrend)
emaSlopeBars = input.int(3, "EMA 21 Slope Bars", minval=1, group=groupTrend)
breakoutLen = input.int(20, "Range Breakout Length", minval=5, group=groupTrend)

groupSession = "Session Rules"
majorEntrySession = input.session("0920-1230", "Major Index Entry Window", group=groupSession)
vixEntrySession = input.session("0920-1145", "India VIX Entry Window", group=groupSession)
manageSession = input.session("0920-1515", "Manage Window", group=groupSession)

groupShortTf = "Short Interval Confirmation"
confirmTfFast = input.timeframe("3", "Fast Confirm TF", group=groupShortTf)
confirmTfSlow = input.timeframe("5", "Slow Confirm TF", group=groupShortTf)

groupMajor = "Major Index Profile"
majorBuyRsiMin = input.int(54, "BUY RSI Min", minval=1, maxval=99, group=groupMajor)
majorBuyRsiMax = input.int(74, "BUY RSI Max", minval=1, maxval=99, group=groupMajor)
majorSellRsiMin = input.int(26, "SELL RSI Min", minval=1, maxval=99, group=groupMajor)
majorSellRsiMax = input.int(46, "SELL RSI Max", minval=1, maxval=99, group=groupMajor)
majorBodyPctMin = input.float(0.12, "Min Candle Body %", minval=0.01, maxval=1.0, step=0.01, group=groupMajor)
majorCooldownBars = input.int(6, "Cooldown Bars", minval=0, group=groupMajor)
majorMinScore = input.float(0.95, "Min Strategy Score", minval=0.5, maxval=3.5, step=0.05, group=groupMajor)

groupVix = "India VIX Profile"
allowVixLongs = input.bool(false, "Allow BUY Signals", group=groupVix)
vixBuyRsiMin = input.int(56, "BUY RSI Min", minval=1, maxval=99, group=groupVix)
vixBuyRsiMax = input.int(72, "BUY RSI Max", minval=1, maxval=99, group=groupVix)
vixSellRsiMin = input.int(28, "SELL RSI Min", minval=1, maxval=99, group=groupVix)
vixSellRsiMax = input.int(48, "SELL RSI Max", minval=1, maxval=99, group=groupVix)
vixBodyPctMin = input.float(0.10, "Min Candle Body %", minval=0.01, maxval=1.0, step=0.01, group=groupVix)
vixCooldownBars = input.int(5, "Cooldown Bars", minval=0, group=groupVix)
vixMinScore = input.float(0.90, "Min Strategy Score", minval=0.5, maxval=3.5, step=0.05, group=groupVix)

isIndiaVix = str.contains(str.upper(syminfo.tickerid), "VIX")
entrySession = isIndiaVix ? vixEntrySession : majorEntrySession
buyRsiMin = isIndiaVix ? vixBuyRsiMin : majorBuyRsiMin
buyRsiMax = isIndiaVix ? vixBuyRsiMax : majorBuyRsiMax
sellRsiMin = isIndiaVix ? vixSellRsiMin : majorSellRsiMin
sellRsiMax = isIndiaVix ? vixSellRsiMax : majorSellRsiMax
bodyPctMin = isIndiaVix ? vixBodyPctMin : majorBodyPctMin
cooldownBars = isIndiaVix ? vixCooldownBars : majorCooldownBars
minScore = isIndiaVix ? vixMinScore : majorMinScore
allowLongs = isIndiaVix ? allowVixLongs : true
allowShorts = true

ema9 = ta.ema(close, emaFastLen)
ema21 = ta.ema(close, emaMidLen)
ema50 = ta.ema(close, emaSlowLen)
vwapValue = ta.vwap(close)
rsi = ta.rsi(close, rsiLen)
[macdLine, macdSignal, _] = ta.macd(close, 12, 26, 9)
macdHist = macdLine - macdSignal
macdHistDelta = macdHist - nz(macdHist[1])
bodyPct = math.abs(close - open) / math.max(high - low, syminfo.mintick)
upperWickPct = (high - math.max(open, close)) / math.max(high - low, syminfo.mintick)
lowerWickPct = (math.min(open, close) - low) / math.max(high - low, syminfo.mintick)
ema21SlopeUp = ema21 > ema21[emaSlopeBars]
ema21SlopeDown = ema21 < ema21[emaSlopeBars]
breakoutHigh = ta.highest(high, breakoutLen)[1]
breakoutLow = ta.lowest(low, breakoutLen)[1]
bbBasis = ta.sma(close, 20)
bbDev = ta.stdev(close, 20) * 2.0
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev
atr10 = ta.atr(10)
kcBasis = ta.ema(close, 20)
kcUpper = kcBasis + 2.0 * atr10
kcLower = kcBasis - 2.0 * atr10
squeezeOn = bbUpper <= kcUpper and bbLower >= kcLower
bodyFloor = math.max(0.08, bodyPctMin * 0.55)
breakoutBodyFloor = math.max(0.10, bodyPctMin * 0.80)

inEntryWindow = not na(time(timeframe.period, entrySession))
inManageWindow = not na(time(timeframe.period, manageSession))

trendBuy = allowLongs and ema9 > ema21 and ema21 > ema50 and close > ema21 and close > vwapValue and rsi >= buyRsiMin and rsi <= buyRsiMax and macdLine > macdSignal and macdHist > 0 and macdHistDelta > 0 and ema21SlopeUp and close > open and bodyPct >= bodyPctMin
trendSell = allowShorts and ema9 < ema21 and ema21 < ema50 and close < ema21 and close < vwapValue and rsi >= sellRsiMin and rsi <= sellRsiMax and macdLine < macdSignal and macdHist < 0 and macdHistDelta < 0 and ema21SlopeDown and close < open and bodyPct >= bodyPctMin

pullbackBuy = allowLongs and ema21 > ema50 and close > ema21 and close > vwapValue and (open <= ema21 or lowerWickPct >= 0.35) and rsi >= math.max(48, buyRsiMin - 6) and rsi <= math.min(78, buyRsiMax + 4) and macdHistDelta > 0 and ema21SlopeUp and close > open and bodyPct >= bodyFloor
pullbackSell = allowShorts and ema21 < ema50 and close < ema21 and close < vwapValue and (open >= ema21 or upperWickPct >= 0.35) and rsi >= math.max(22, sellRsiMin - 4) and rsi <= math.min(52, sellRsiMax + 6) and macdHistDelta < 0 and ema21SlopeDown and close < open and bodyPct >= bodyFloor

breakoutBuy = allowLongs and close > breakoutHigh and ema21 > ema50 and close > vwapValue and rsi >= math.max(52, buyRsiMin - 2) and macdHist > 0 and ema21SlopeUp and close > open and bodyPct >= breakoutBodyFloor
breakoutSell = allowShorts and close < breakoutLow and ema21 < ema50 and close < vwapValue and rsi <= math.min(48, sellRsiMax + 2) and macdHist < 0 and ema21SlopeDown and close < open and bodyPct >= breakoutBodyFloor

squeezeBuy = allowLongs and squeezeOn and close > bbUpper and close > ema9 and close > vwapValue and rsi >= math.max(52, buyRsiMin - 2) and macdHistDelta > 0 and ema21SlopeUp
squeezeSell = allowShorts and squeezeOn and close < bbLower and close < ema9 and close < vwapValue and rsi <= math.min(48, sellRsiMax + 2) and macdHistDelta < 0 and ema21SlopeDown

buyScore = (trendBuy ? 1.0 : 0.0) + (pullbackBuy ? 0.85 : 0.0) + (breakoutBuy ? 0.95 : 0.0) + (squeezeBuy ? 0.90 : 0.0)
sellScore = (trendSell ? 1.0 : 0.0) + (pullbackSell ? 0.85 : 0.0) + (breakoutSell ? 0.95 : 0.0) + (squeezeSell ? 0.90 : 0.0)

addFamily(label, passed, current) =>
    passed ? (str.length(current) > 0 ? current + "|" + label : label) : current

buyFamilies = ""
buyFamilies := addFamily("trend_continuation", trendBuy, buyFamilies)
buyFamilies := addFamily("ema_pullback_reclaim", pullbackBuy, buyFamilies)
buyFamilies := addFamily("range_breakout", breakoutBuy, buyFamilies)
buyFamilies := addFamily("squeeze_expansion", squeezeBuy, buyFamilies)

sellFamilies = ""
sellFamilies := addFamily("trend_continuation", trendSell, sellFamilies)
sellFamilies := addFamily("ema_pullback_reject", pullbackSell, sellFamilies)
sellFamilies := addFamily("range_breakdown", breakoutSell, sellFamilies)
sellFamilies := addFamily("squeeze_expansion", squeezeSell, sellFamilies)

baseBuySetup = buyScore >= minScore and buyScore > sellScore
baseSellSetup = sellScore >= minScore and sellScore > buyScore
confirmFastState = request.security(syminfo.tickerid, confirmTfFast, baseBuySetup ? 1 : baseSellSetup ? -1 : 0, barmerge.gaps_off, barmerge.lookahead_off)
confirmSlowState = request.security(syminfo.tickerid, confirmTfSlow, baseBuySetup ? 1 : baseSellSetup ? -1 : 0, barmerge.gaps_off, barmerge.lookahead_off)
buyAlignment = (confirmFastState == 1 ? 1 : 0) + (confirmSlowState == 1 ? 1 : 0)
sellAlignment = (confirmFastState == -1 ? 1 : 0) + (confirmSlowState == -1 ? 1 : 0)
strongBuyWithoutAlignment = buyScore >= math.max(minScore + 0.90, 1.90)
strongSellWithoutAlignment = sellScore >= math.max(minScore + 0.90, 1.90)
buySetup = baseBuySetup and (buyAlignment >= 1 or strongBuyWithoutAlignment)
sellSetup = baseSellSetup and (sellAlignment >= 1 or strongSellWithoutAlignment)

var int lastEntryBar = na
cooldownReady = na(lastEntryBar) or bar_index - lastEntryBar >= cooldownBars
buySignal = inEntryWindow and cooldownReady and buySetup and strategy.position_size <= 0
sellSignal = inEntryWindow and cooldownReady and sellSetup and strategy.position_size >= 0
forceExit = not inManageWindow and strategy.position_size != 0

buyConfidence = math.min(0.95, 0.58 + buyScore * 0.12)
sellConfidence = math.min(0.95, 0.58 + sellScore * 0.12)
candleTimeIst = str.format_time(time, "yyyy-MM-dd HH:mm:ss", "Asia/Kolkata")

buyPayload = "{\"symbol\":\"" + syminfo.ticker + "\",\"signal_action\":\"BUY\",\"confidence\":" + str.tostring(buyConfidence, "#.##") + ",\"source\":\"pine_v2\",\"metadata_json\":{\"strategy\":\"multi_strategy_confluence\",\"families\":\"" + buyFamilies + "\",\"buy_score\":" + str.tostring(buyScore, "#.##") + ",\"sell_score\":" + str.tostring(sellScore, "#.##") + ",\"buy_alignment\":" + str.tostring(buyAlignment) + ",\"sell_alignment\":" + str.tostring(sellAlignment) + ",\"confirm_fast_tf\":\"" + confirmTfFast + "\",\"confirm_slow_tf\":\"" + confirmTfSlow + "\",\"timeframe\":\"" + timeframe.period + "\",\"candle_ts\":\"" + str.tostring(time) + "\",\"candle_time_ist\":\"" + candleTimeIst + "\"}}"
sellPayload = "{\"symbol\":\"" + syminfo.ticker + "\",\"signal_action\":\"SELL\",\"confidence\":" + str.tostring(sellConfidence, "#.##") + ",\"source\":\"pine_v2\",\"metadata_json\":{\"strategy\":\"multi_strategy_confluence\",\"families\":\"" + sellFamilies + "\",\"buy_score\":" + str.tostring(buyScore, "#.##") + ",\"sell_score\":" + str.tostring(sellScore, "#.##") + ",\"buy_alignment\":" + str.tostring(buyAlignment) + ",\"sell_alignment\":" + str.tostring(sellAlignment) + ",\"confirm_fast_tf\":\"" + confirmTfFast + "\",\"confirm_slow_tf\":\"" + confirmTfSlow + "\",\"timeframe\":\"" + timeframe.period + "\",\"candle_ts\":\"" + str.tostring(time) + "\",\"candle_time_ist\":\"" + candleTimeIst + "\"}}"
exitPayload = "{\"symbol\":\"" + syminfo.ticker + "\",\"signal_action\":\"EXIT\",\"confidence\":0.0,\"source\":\"pine_v2\",\"metadata_json\":{\"strategy\":\"multi_strategy_confluence\",\"reason\":\"FORCE_SQUAREOFF\",\"timeframe\":\"" + timeframe.period + "\",\"candle_ts\":\"" + str.tostring(time) + "\",\"candle_time_ist\":\"" + candleTimeIst + "\"}}"

if buySignal
    strategy.entry("BUY_CE_SIGNAL", strategy.long, alert_message=buyPayload)
    alert(buyPayload, alert.freq_once_per_bar_close)
    lastEntryBar := bar_index

if sellSignal
    strategy.entry("SELL_PE_SIGNAL", strategy.short, alert_message=sellPayload)
    alert(sellPayload, alert.freq_once_per_bar_close)
    lastEntryBar := bar_index

if forceExit
    strategy.close_all(comment="FORCE_SQUAREOFF", alert_message=exitPayload)
    alert(exitPayload, alert.freq_once_per_bar_close)

plot(ema9, "EMA 9", color=color.new(color.green, 0), linewidth=1)
plot(ema21, "EMA 21", color=color.new(color.blue, 0), linewidth=2)
plot(ema50, "EMA 50", color=color.new(color.orange, 0), linewidth=2)
plot(vwapValue, "VWAP", color=color.new(color.aqua, 0), linewidth=1)

plotshape(baseBuySetup and not buySignal, title="BUY Setup", style=shape.circle, text="B", location=location.belowbar, color=color.new(color.lime, 35), textcolor=color.white, size=size.tiny)
plotshape(baseSellSetup and not sellSignal, title="SELL Setup", style=shape.circle, text="S", location=location.abovebar, color=color.new(color.orange, 35), textcolor=color.white, size=size.tiny)
plotshape(buySignal, title="BUY", style=shape.labelup, text="BUY", location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white, size=size.small)
plotshape(sellSignal, title="SELL", style=shape.labeldown, text="SELL", location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.small)

bgcolor(inEntryWindow ? color.new(color.teal, 94) : na)

alertcondition(buySignal, title="BUY Signal", message="BUY")
alertcondition(sellSignal, title="SELL Signal", message="SELL")
alertcondition(forceExit, title="Force Squareoff", message="EXIT")
