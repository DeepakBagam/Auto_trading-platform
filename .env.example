ENV=dev
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata

# SQLite now (easy local): sqlite:///./trading.db
# PostgreSQL later: postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./trading.db

DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading
DB_USER=trading_user
DB_PASSWORD=trading_pass

UPSTOX_BASE_URL=https://api.upstox.com
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=
UPSTOX_ACCESS_TOKEN=
UPSTOX_ANALYTICS_TOKEN=
UPSTOX_INSTRUMENT_KEYS=NSE_INDEX|Nifty 50,NSE_INDEX|Nifty Bank,NSE_INDEX|India VIX,BSE_INDEX|SENSEX
UPSTOX_HISTORY_API_VERSION=auto

NEWSAPI_KEY=
FINNHUB_API_KEY=
ENABLE_FINNHUB=true

NEWS_POLL_MINUTES=10
CANDLE_POLL_MINUTES=1
MARKET_DATA_MODE=polling
UPSTOX_WEBSOCKET_MODE=full
UPSTOX_WEBSOCKET_RECONNECT_INTERVAL_SECONDS=5
UPSTOX_WEBSOCKET_RETRY_COUNT=1000
MODEL_ARTIFACTS_DIR=models/artifacts
FEATURE_SCHEMA_VERSION=v3
LABEL_SCHEMA_VERSION=v3
TRAIN_WINDOW_DAYS=1500
VALIDATION_WINDOW_DAYS=250
RETRAIN_FREQUENCY_DAYS=7
POINT_IN_TIME_STALE_HOURS=24
MISSING_CANDLE_RATIO_MAX=0.03
PROMOTION_ECE_MAX=0.05
PROMOTION_COVERAGE_TARGET=0.80
PROMOTION_COVERAGE_TOLERANCE=0.05
API_HOST=0.0.0.0
API_PORT=8000
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TO_EMAILS=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

EXECUTION_ENABLED=true
EXECUTION_MODE=paper
EXECUTION_SYMBOLS=Nifty 50,Bank Nifty,India VIX,SENSEX
EXECUTION_INTERVAL=1minute
EXECUTION_STRATEGY_MODE=auto
EXECUTION_ALLOW_OPTION_WRITING=false
EXECUTION_POLL_SECONDS=5
EXECUTION_SYMBOL_LOT_SIZES=Nifty 50:65,Bank Nifty:30,SENSEX:20
EXECUTION_CAPITAL=500000
EXECUTION_LOT_SIZE=1
PINE_WEBHOOK_SECRET=
LIVE_EXECUTION_BLOCKED_SYMBOLS=India VIX

# Signal thresholds
ML_BUY_THRESHOLD=0.62
ML_SELL_THRESHOLD=0.62
ML_MIN_EXPECTED_MOVE=80
PINE_SIGNAL_MAX_AGE_SECONDS=60
AI_QUALITY_MINIMUM=65
COMBINED_SCORE_THRESHOLD=0.65

# Stop loss settings
TSL_ACTIVATION_PERCENT=0.05
TSL_TRAIL_PERCENT=0.03
TARGET_PROFIT_PERCENT=0.30

# Risk management
CAPITAL_PER_TRADE_PERCENT=0.02
MAX_DAILY_TRADES=5
MAX_SIMULTANEOUS_TRADES=1
DAILY_LOSS_LIMIT_PERCENT=0.05
FORCE_SQUAREOFF_TIME=15:15
ENTRY_WINDOW_START=09:20
ENTRY_WINDOW_END=13:30

# Redis Configuration (for Celery)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Broker Configuration (multi-broker support)
BROKER_NAME=upstox
LOG_DIR=logs
